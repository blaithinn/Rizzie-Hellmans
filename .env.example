# Infura or Alchemy Sepolia RPC endpoint
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Private key of the funded Sepolia wallet the server uses to sign transactions (no 0x prefix needed)
SERVER_WALLET_PRIVATE_KEY=your_private_key_here

# Deployed MessageHash contract address on Sepolia
CONTRACT_ADDRESS=0xe562bD4F0E06783a7133Dc1d4dD486406eD753DC

# Secret used to sign and verify JWT tokens — must be a long random string (e.g. output of: openssl rand -hex 64)
JWT_SECRET=your_long_random_secret_here
